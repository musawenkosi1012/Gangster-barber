{
  "version": 2,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/next" },
    { "src": "backend/index.py", "use": "@vercel/python" },
    { "src": "paynow/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/payments/(.*)", "dest": "paynow/index.py" },
    { "src": "/api/(.*)", "dest": "backend/index.py" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
